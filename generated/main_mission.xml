<root BTCPP_format="4" main_tree_to_execute="MainMission">

<BehaviorTree ID="MainMission">
  <ReactiveFallback name="mission_root">
      <Sequence name="mission_sequence">
        <SubTree ID="UAV_Search"/>
        <SubTree ID="USV_Track"/>
        <SubTree ID="Joint_Encircle"/>
      </Sequence>
      <Sequence name="abort_or_recover">
        <ReturnHome vehicle_id="uav_1"/>
        <ReturnHome vehicle_id="uav_2"/>
        <ReturnHome vehicle_id="uav_3"/>
        <ReturnHome vehicle_id="uav_4"/>
        <ReturnHome vehicle_id="uav_5"/>
        <ReturnHome vehicle_id="ugv_1"/>
        <ReturnHome vehicle_id="ugv_2"/>
        <ReturnHome vehicle_id="usv_1"/>
        <ReturnHome vehicle_id="usv_2"/>
      </Sequence>
  </ReactiveFallback>
</BehaviorTree>

<BehaviorTree ID="CommonSafety">
  <Sequence>
    <BatteryOK vehicle_id="{vehicle_id}" min_battery_pct="{min_battery_pct}"/>
    <WithinGeofence vehicle_id="{vehicle_id}" geofence_id="{geofence_id}"/>
    <OutsideRestrictedZone vehicle_id="{vehicle_id}" restricted_zone_list="{restricted_zone_list}"/>
  </Sequence>
</BehaviorTree>

<BehaviorTree ID="UAV_Search">
  <Sequence>
    <SubTree ID="CommonSafety" vehicle_id="uav_1" min_battery_pct="20.0" geofence_id="{geofence_id}" restricted_zone_list="{restricted_zone_list}"/>
    <Timeout msec="60000">
      <GoToArea vehicle_id="uav_1" area_id="{mission_area}"/>
    </Timeout>
    <RetryUntilSuccessful num_attempts="2">
      <Timeout msec="150000">
        <SearchArea vehicle_id="uav_1" area_id="{mission_area}" pattern="lawnmower" sensor_mode="thermal"/>
      </Timeout>
    </RetryUntilSuccessful>
    <TargetDetected source_vehicle="uav_1" target_id="{target_id}"/>
  </Sequence>
</BehaviorTree>

<BehaviorTree ID="USV_Track">
  <Sequence>
    <SubTree ID="CommonSafety" vehicle_id="uav_3" min_battery_pct="20.0" geofence_id="{geofence_id}" restricted_zone_list="{restricted_zone_list}"/>
    <Timeout msec="30000">
      <HandoffTarget vehicle_id="uav_3" target_id="{target_id}"/>
    </Timeout>
    <TargetAssigned vehicle_id="uav_3" target_id="{target_id}"/>
    <Timeout msec="90000">
      <TrackTarget vehicle_id="uav_3" target_id="{target_id}"/>
    </Timeout>
    <TrackStable vehicle_id="uav_3" target_id="{target_id}"/>
  </Sequence>
</BehaviorTree>

<BehaviorTree ID="Joint_Encircle">
  <Timeout msec="60000">
  <Parallel success_count="3" failure_count="1">
    <EncircleTarget vehicle_id="uav_5" target_id="{target_id}" radius_m="18.0" standoff_m="10.0"/>
    <EncircleTarget vehicle_id="ugv_2" target_id="{target_id}" radius_m="18.0" standoff_m="10.0"/>
    <EncircleTarget vehicle_id="usv_2" target_id="{target_id}" radius_m="18.0" standoff_m="10.0"/>
  </Parallel>
  </Timeout>
</BehaviorTree>

</root>